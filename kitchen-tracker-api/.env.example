# Copy this file to .env locally if you want a reference, but do not commit real keys.
# The Spring Boot app reads these values from your shell environment.

GEMINI_API_KEY=replace_with_your_gemini_key
GEMINI_MODEL=gemini-2.5-flash

VAPID_PUBLIC_KEY=replace_with_your_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_your_vapid_private_key

NOTIFICATION_CRON_TOKEN=replace_with_a_long_random_secret

# Deployment-only examples for Postgres and frontend CORS.
DATABASE_URL=jdbc:postgresql://host:5432/database
DATABASE_DRIVER=org.postgresql.Driver
DATABASE_USERNAME=replace_with_database_user
DATABASE_PASSWORD=replace_with_database_password
FRONTEND_ORIGINS=https://your-frontend.vercel.app
